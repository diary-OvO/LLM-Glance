{
  "manifest_version": 3,
  "name": "LLM Glance",
  "version": "1.0.0",
  "description": "CodeGlance-style user chat minimap for ChatGPT conversations.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "src/popup.html",
    "default_title": "LLM Glance"
  },
  "commands": {
    "toggle-glance": {
      "suggested_key": {
        "default": "Alt+Shift+G"
      },
      "description": "Toggle LLM Glance"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
